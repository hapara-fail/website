---
import BaseLayout from '../layouts/BaseLayout.astro';
import Copy from '@lucide/astro/icons/copy';
---

<BaseLayout
  title="Contribute | hapara.fail"
  description="Support hapara.fail’s mission. Donate via PayPal, Buy Me a Coffee, or crypto, and learn how to contribute code and research on GitHub."
  canonicalUrl="https://www.hapara.fail/contribute"
  pageStyles={['/css/contribute.css']}
  extraScripts={['/js/scroll-reveal.js', '/js/contribute.js']}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Contribute | hapara.fail',
    url: 'https://www.hapara.fail/contribute',
    description:
      'Support hapara.fail’s mission. Donate via PayPal, Buy Me a Coffee, or crypto, and learn how to contribute code and research on GitHub.',
    isPartOf: {
      '@type': 'WebSite',
      name: 'hapara.fail',
      url: 'https://www.hapara.fail/',
    },
    publisher: {
      '@type': 'Organization',
      name: 'hapara.fail',
      url: 'https://www.hapara.fail/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.hapara.fail/images/favicon-96x96.png',
      },
    },
  }}
>
  <section class="page-hero content-section">
    <div class="parallax-bg"></div>
    <div class="container reveal reveal-blur">
      <h1 class="gradient-text">Support the Mission</h1>
      <p>
        hapara.fail is a community-driven project. We rely on your support to develop tools, publish
        research, and fight for student privacy. Every contribution helps keep this project
        independent and freely available to all.
      </p>
    </div>
  </section>

  <section id="donate" class="content-section">
    <div class="container">
      <div class="section-header reveal reveal-up">
        <h2 class="gradient-text">Financial Contributions</h2>
        <p>
          Donations directly fund our server costs, development efforts, and advocacy. We appreciate
          any support you can provide.
        </p>
      </div>
      <div class="contribution-grid" data-reveal-stagger>
        <div class="contribution-card reveal reveal-scale">
          <svg
            class="icon"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="currentColor"
              d="M15.607 4.653H8.941L6.645 19.251H1.82L4.862 0h7.995c3.754 0 6.375 2.294 6.473 5.513-.648-.478-2.105-.86-3.722-.86m6.57 5.546c0 3.41-3.01 6.853-6.958 6.853h-2.493L11.595 24H6.74l1.845-11.538h3.592c4.208 0 7.346-3.634 7.153-6.949a5.24 5.24 0 0 1 2.848 4.686M9.653 5.546h6.408c.907 0 1.942.222 2.363.541-.195 2.741-2.655 5.483-6.441 5.483H8.714Z"
            ></path>
          </svg>
          <h3>PayPal</h3>
          <p>
            A fast and secure way to support our project directly. Your contribution helps us cover
            operational costs and continue our work.
          </p>
          <button class="cta-button cta-button--disabled" disabled>Unavailable</button>
        </div>

        <div class="contribution-card reveal reveal-scale">
          <svg
            class="icon"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="currentColor"
              d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.31-.025-1.966-.022-.699.004-1.556-.06-2.095-.58-.475-.458-.54-1.174-.605-1.793l-.731-7.013-.322-3.094c-.037-.351-.286-.695-.678-.678-.336.015-.718.3-.678.679l.228 2.185.949 9.112c.147 1.344 1.174 2.068 2.446 2.272.742.12 1.503.144 2.257.156.966.016 1.942.053 2.892-.122 1.408-.258 2.465-1.198 2.616-2.657.34-3.332.683-6.663 1.024-9.995l.215-2.087a.484.484 0 01.39-.426c.402-.078.787-.212 1.074-.518.455-.488.546-1.124.385-1.766zm-1.478.772c-.145.137-.363.201-.578.233-2.416.359-4.866.54-7.308.46-1.748-.06-3.477-.254-5.207-.498-.17-.024-.353-.055-.47-.18-.22-.236-.111-.71-.054-.995.052-.26.152-.609.463-.646.484-.057 1.046.148 1.526.22.577.088 1.156.159 1.737.212 2.48.226 5.002.19 7.472-.14.45-.06.899-.13 1.345-.21.399-.072.84-.206 1.08.206.166.281.188.657.162.974a.544.544 0 01-.169.364zm-6.159 3.9c-.862.37-1.84.788-3.109.788a5.884 5.884 0 01-1.569-.217l.877 9.004c.065.78.717 1.38 1.5 1.38 0 0 1.243.065 1.658.065.447 0 1.786-.065 1.786-.065.783 0 1.434-.6 1.499-1.38l.94-9.95a3.996 3.996 0 00-1.322-.238c-.826 0-1.491.284-2.26.613z"
            ></path>
          </svg>
          <h3>Buy Me a Coffee</h3>
          <p>
            A simple way to support the project with options for card, bank transfer, and Cash App
            Pay.
          </p>
          <a
            href="https://buymeacoffee.com/hapara.fail"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-button">Buy Me A Coffee</a
          >
        </div>

        <div class="contribution-card full-width reveal reveal-scale">
          <svg
            class="icon"
            aria-hidden="true"
            focusable="false"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="currentColor"
              d="M23.638 14.904c-1.602 6.43-8.113 10.34-14.542 8.736C2.67 22.05-1.244 15.525.362 9.105 1.962 2.67 8.475-1.243 14.9.358c6.43 1.605 10.342 8.115 8.738 14.548v-.002zm-6.35-4.613c.24-1.59-.974-2.45-2.64-3.03l.54-2.153-1.315-.33-.525 2.107c-.345-.087-.705-.167-1.064-.25l.526-2.127-1.32-.33-.54 2.165c-.285-.067-.565-.132-.84-.2l-1.815-.45-.35 1.407s.975.225.955.236c.535.136.63.486.615.766l-1.477 5.92c-.075.166-.24.406-.614.314.015.02-.96-.24-.96-.24l-.66 1.51 1.71.426.93.242-.54 2.19 1.32.327.54-2.17c.36.1.705.19 1.05.273l-.51 2.154 1.32.33.545-2.19c2.24.427 3.93.257 4.64-1.774.57-1.637-.03-2.58-1.217-3.196.854-.193 1.5-.76 1.68-1.93h.01zm-3.01 4.22c-.404 1.64-3.157.75-4.05.53l.72-2.9c.896.23 3.757.67 3.33 2.37zm.41-4.24c-.37 1.49-2.662.735-3.405.55l.654-2.64c.744.18 3.137.524 2.75 2.084v.006z"
            ></path>
          </svg>
          <h3>Cryptocurrency</h3>
          <p>
            We welcome anonymous donations via several cryptocurrencies. Click the copy icon for any
            address.
          </p>
          <ul class="crypto-list">
            <li class="crypto-item">
              <strong>BTC</strong>
              <code id="btc-addr" class="crypto-address"
                >bc1q2w3sl5vtem5vl85949vjx6wpxrg92c4c0u37wz</code
              >
              <button
                class="copy-btn"
                data-copy-target="#btc-addr"
                aria-label="Copy Bitcoin address"
              >
                <Copy size={24} aria-hidden="true" />
                <span class="copied-message">Copied!</span>
              </button>
            </li>
            <li class="crypto-item">
              <strong>ETH</strong>
              <code id="eth-addr" class="crypto-address"
                >0x154B937B3217E8cF7a26384c4AACc7F419c66b27</code
              >
              <button
                class="copy-btn"
                data-copy-target="#eth-addr"
                aria-label="Copy Ethereum address"
              >
                <Copy size={24} aria-hidden="true" />
                <span class="copied-message">Copied!</span>
              </button>
            </li>
            <li class="crypto-item">
              <strong>LTC</strong>
              <code id="ltc-addr" class="crypto-address">LcC4Up1BCEHTqMZRYb7GmFD1fRMjJ8yair</code>
              <button
                class="copy-btn"
                data-copy-target="#ltc-addr"
                aria-label="Copy Litecoin address"
              >
                <Copy size={24} aria-hidden="true" />
                <span class="copied-message">Copied!</span>
              </button>
            </li>
            <li class="crypto-item">
              <strong>SOL</strong>
              <code id="sol-addr" class="crypto-address"
                >Gb25osyrTgsgVRCafPPTbfcRJWtjFFKzUjtHuLmdqrFp</code
              >
              <button
                class="copy-btn"
                data-copy-target="#sol-addr"
                aria-label="Copy Solana address"
              >
                <Copy size={24} aria-hidden="true" />
                <span class="copied-message">Copied!</span>
              </button>
            </li>
          </ul>
        </div>

        <div class="contribution-card full-width reveal reveal-scale">
          <h3>Other Methods & Discord Role</h3>
          <p>
            For alternative donation methods (e.g. cash), please contact
            <a href="mailto:a9x@hapara.fail" style="color: var(--accent-2)">a9x@hapara.fail</a>. For
            your security, please only use this specific address for such inquiries. After a
            donation of $5 or more, you can claim your <code>@Donator</code> role on Discord by emailing
            us with proof of transaction.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="contribute" class="content-section">
    <div class="container">
      <div class="os-card reveal reveal-up">
        <h2 class="gradient-text">Become a Contributor</h2>
        <p>
          Financial support isn't the only way to help. Our projects are open-source because we
          believe in the power of community collaboration. If you're a developer, researcher, or
          just passionate about privacy, your skills are invaluable.
        </p>
        <a
          href="https://github.com/hapara-fail"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          <svg
            aria-hidden="true"
            focusable="false"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
          <span>Contribute on GitHub</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
