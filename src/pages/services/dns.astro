              </svg>
              <span>GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div slot="body">
    <!-- DNS Info Modal -->
    <div id="dns-modal-overlay" class="dns-modal-overlay" hidden>
      <div
        class="dns-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="dns-modal-title"
        aria-describedby="dns-modal-description"
      >
        <button id="dns-modal-close" class="dns-modal-close" aria-label="Close modal">
          &times;
        </button>

        <!-- Step 1: ToS -->
        <div id="dns-step-tos" class="dns-step">
          <h3 id="dns-modal-title" class="dns-modal-title">Service Agreement</h3>
          <p id="dns-modal-description" class="dns-modal-text">
            By using hapara.fail DNS, you agree to our
            <a href="/terms" target="_blank" rel="noopener noreferrer">Terms of Service</a> and
            <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>. Misuse
            or abuse of the service may result in your IP being blocked.
          </p>
          <label class="dns-checkbox-wrapper" for="tos-agreement-checkbox">
            <input type="checkbox" id="tos-agreement-checkbox" />
            <span class="dns-custom-checkbox">
              <Check size={18} stroke-width={3} aria-hidden="true" />
            </span>
            <span class="dns-checkbox-label">I agree to the Terms and Privacy Policy</span>
          </label>
          <button id="tos-proceed-btn" class="cta-button cta-button--disabled" disabled>
            Proceed
          </button>
        </div>

        <!-- Step 2: IPs -->
        <div id="dns-step-info" class="dns-step" hidden>
          <h3 id="dns-modal-info-title" class="dns-modal-title">DNS Addresses</h3>
          <p id="dns-modal-info-description" class="dns-modal-text">
            Copy the server address you need for your device or encrypted DNS setup.
          </p>

          <!-- DNS Server 1 -->
          <div
            class="dns-server-block dns-server-block--unavailable"
            aria-label="Server 1 unavailable"
          >
            <h4 class="dns-server-heading">Server 1</h4>
            <div class="dns-server-unavailable-surface">
              <div class="dns-server-unavailable-content" aria-hidden="true" inert>
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px">
                  <div class="dns-location-tag" style="margin-bottom: 0">
                    <MapPin size={16} stroke-width={2} aria-hidden="true" />
                    <span class="location-text">South Carolina, USA</span>
                  </div>
                  <a
                    href="https://status.hapara.fail/"
                    target="_blank"
                    rel="noopener noreferrer"
                    id="dns-status-tag"
                    class="dns-status-tag"
                    style="margin-bottom: 0; text-decoration: none"
                  >
                    <div class="status-dot"></div>
                    <span class="status-text">Unavailable</span>
                  </a>
                </div>

                <div class="dns-info-group">
                  <div class="dns-info-label">IPv4 Address</div>
                  <div class="dns-copy-row">
                    <code id="dns-ipv4">Unavailable</code>
                    <button
                      class="copy-btn"
                      aria-label="Copy IPv4"
                      data-copy-target="#dns-ipv4"
                      disabled
                    >
                      <Copy size={24} />
                      <span class="copied-message">Copied!</span>
                    </button>
                  </div>
                </div>

                <div class="dns-info-group">
                  <div class="dns-info-label">DoH / DoT / DoQ</div>
                  <div class="dns-copy-row">
                    <code style="font-size: 0.9em" id="dns-doh">Unavailable</code>
                    <button
                      class="copy-btn"
                      aria-label="Copy DoH"
                      data-copy-target="#dns-doh"
                      disabled
                    >
                      <Copy size={24} />
                      <span class="copied-message">Copied!</span>
                    </button>
                  </div>
                </div>
              </div>
              <div class="dns-server-unavailable-overlay" aria-hidden="true">
                <span class="dns-server-unavailable-title">Unavailable</span>
                <span class="dns-server-unavailable-copy">Use Server 2 below</span>
              </div>
            </div>
          </div>

          <hr class="dns-server-divider" />

          <!-- DNS Server 2 -->
          <div class="dns-server-block">
            <h4 class="dns-server-heading">Server 2</h4>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px">
              <div class="dns-location-tag" style="margin-bottom: 0">
                <MapPin size={16} stroke-width={2} aria-hidden="true" />
                <span class="location-text">New York, NY</span>
              </div>
              <a
                href="https://status.hapara.fail/"
                target="_blank"
                rel="noopener noreferrer"
                id="dns2-status-tag"
                class="dns-status-tag"
                style="margin-bottom: 0; text-decoration: none"
              >
                <div class="status-dot"></div>
                <span class="status-text" aria-live="polite">Checking...</span>
              </a>
            </div>

            <div class="dns-info-group">
              <div class="dns-info-label">IPv4 Address</div>
              <div class="dns-copy-row">
                <code id="dns2-ipv4">152.42.152.171</code>
                <button class="copy-btn" aria-label="Copy IPv4" data-copy-target="#dns2-ipv4">
                  <Copy size={24} />
                  <span class="copied-message">Copied!</span>
                </button>
              </div>
            </div>

            <div class="dns-info-group">
              <div class="dns-info-label">DoH / DoT / DoQ</div>
              <div class="dns-copy-row">
                <code style="font-size: 0.9em" id="dns2-doh"
                  >https://dns2.hapara.fail/dns-query</code
                >
                <button class="copy-btn" aria-label="Copy DoH" data-copy-target="#dns2-doh">
                  <Copy size={24} />
                  <span class="copied-message">Copied!</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <p id="dns-modal-status" class="visually-hidden" role="status" aria-live="polite"></p>
    </div>
  </div>
</BaseLayout>
