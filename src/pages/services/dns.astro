---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import LockOpen from '@lucide/astro/icons/lock-open';
import FileSearch from '@lucide/astro/icons/file-search';
import ExternalLink from '@lucide/astro/icons/external-link';
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Check from '@lucide/astro/icons/check';
import X from '@lucide/astro/icons/x';
---

<BaseLayout
  title="DNS Migration Guide | hapara.fail"
  description="The public DNS resolver is retiring. Self-host the service or prepare to use the blocklist in NextDNS, Control D, or another DNS provider."
  canonicalUrl="https://www.hapara.fail/services/dns"
  pageStyles={['/css/article.css', '/css/dns-service.css']}
  extraScripts={['/js/scroll-reveal.js', '/js/nextdns-importer.js']}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'DNS Migration Guide | hapara.fail',
    url: 'https://www.hapara.fail/services/dns',
    description:
      'The public DNS resolver is retiring. Self-host the service or prepare to use the blocklist in NextDNS, Control D, or another DNS provider.',
    isPartOf: {
      '@type': 'WebSite',
      name: 'hapara.fail',
      url: 'https://www.hapara.fail/',
    },
  }}
>
  <section class="page-hero dns-migration-hero">
    <div class="parallax-bg"></div>
    <div class="container reveal reveal-blur">
      <h1 class="gradient-text">Keep the blocklist. Start with managed DNS.</h1>
      <p>
        The public DNS resolver retires on July 31, 2026. The easiest replacement is NextDNS or
        Control D; self-hosting remains available for advanced users who want full control.
      </p>
      <div class="dns-hero-actions">
        <a class="cta-button" href="#managed-providers">
          Use managed DNS
          <ExternalLink size={18} aria-hidden="true" />
        </a>
        <a class="cta-button cta-button--secondary" href="#self-hosting">
          Compare options
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section
    class="content-section"
    style="background-color: var(--bg-offset); border-top: 1px solid var(--border-color)"
  >
    <div class="container">
      <div class="callout-warning dns-retirement-notice reveal reveal-up">
        <p>
          <strong>What is changing:</strong> the hosted resolver addresses are going away. The easiest
          path is a managed DNS provider; self-hosting remains available for advanced users.
        </p>
        <p>
          Need the full context? Read the{' '}
          <a href="/blog/public-dns-resolver-shutdown-notice">public resolver shutdown notice</a>.
        </p>
      </div>

      <div class="section-header reveal reveal-up" id="migration-paths">
        <h2 class="gradient-text">Pick the right path</h2>
        <p>
          Start with the card that describes your situation. Each card is clickable and takes you
          straight to the next useful place.
        </p>
      </div>

      <div class="migration-card-grid" data-reveal-stagger>
        <a
          class="migration-card migration-card--recommended reveal reveal-scale"
          href="#managed-providers"
          aria-label="Use NextDNS or Control D as the easiest migration path"
        >
          <span class="migration-card__badge">Easiest</span>
          <span class="migration-card__icon">
            <LockOpen size={30} stroke-width={1.8} aria-hidden="true" />
          </span>
          <span class="migration-card__label">Best starting point</span>
          <h3>Use NextDNS or Control D</h3>
          <p>
            This is the easiest route for most people. Use the NextDNS importer below to sync the
            maintained hapara.fail blocklist into your own profile.
          </p>
          <span class="migration-card__footer">
            Preview provider path
            <ArrowRight class="migration-card__arrow" size={18} aria-hidden="true" />
          </span>
        </a>

        <a
          class="migration-card reveal reveal-scale"
          href="https://docs.hapara.fail/self-hosting/dns"
          aria-label="Self-host the hapara.fail DNS resolver as an advanced option"
        >
          <span class="migration-card__icon">
            <ShieldCheck size={30} stroke-width={1.8} aria-hidden="true" />
          </span>
          <span class="migration-card__label">Advanced users</span>
          <h3>Self-host the DNS</h3>
          <p>
            More manual, more control. Use this path if you already run DNS infrastructure or want
            to manage every piece yourself.
          </p>
          <span class="migration-card__footer">
            Open self-hosting docs
            <ExternalLink class="migration-card__arrow" size={18} aria-hidden="true" />
          </span>
        </a>

        <a
          class="migration-card reveal reveal-scale"
          href="#blocklist-sources"
          aria-label="View raw blocklist feeds"
        >
          <span class="migration-card__icon">
            <FileSearch size={30} stroke-width={1.8} aria-hidden="true" />
          </span>
          <span class="migration-card__label">Building your own workflow?</span>
          <h3>Use the raw feeds</h3>
          <p>
            Pull the maintained blocklist directly from GitHub or jsDelivr for scripts, self-hosted
            stacks, and future import tools.
          </p>
          <span class="migration-card__footer">
            View feed URLs
            <ArrowRight class="migration-card__arrow" size={18} aria-hidden="true" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <section
    id="managed-providers"
    class="content-section"
    style="border-top: 1px solid var(--border-color)"
  >
    <div class="container reveal reveal-blur">
      <div class="section-header">
        <h2 class="gradient-text">Managed DNS importers</h2>
        <p>
          This is the easiest migration surface. The NextDNS importer fetches the live blocklist,
          converts it from ABP syntax, and adds block rules to the denylist plus exception rules to
          the allowlist.
        </p>
      </div>

      <div class="provider-placeholder-grid" data-reveal-stagger>
        <article class="provider-placeholder-card nextdns-importer-card reveal reveal-scale">
          <h3>NextDNS</h3>
          <p>
            Add every domain from the maintained hapara.fail blocklist to a NextDNS profile's
            denylist, while sending ABP allow rules to the profile's allowlist. Your API key is sent
            to a same-origin proxy only to call NextDNS and is not stored by this site.
          </p>
          <button class="cta-button" id="open-nextdns-modal">
            Open NextDNS Importer
            <ArrowRight size={18} aria-hidden="true" />
          </button>
        </article>

        <article class="provider-placeholder-card reveal reveal-scale">
          <h3>Control D</h3>
          <p>
            Future goal: provide a Control D-ready import path that keeps the user experience close
            to self-hosting while staying managed.
          </p>
          <button class="cta-button cta-button--secondary" id="open-controld-modal">
            Open Control D Importer
            <ArrowRight size={18} aria-hidden="true" />
          </button>
        </article>
      </div>
    </div>
  </section>

  <section
    id="self-hosting"
    class="content-section"
    style="background-color: var(--bg-offset); border-top: 1px solid var(--border-color)"
  >
    <div class="container reveal reveal-blur">
      <div class="section-header">
        <h2 class="gradient-text">Self-hosting for advanced users</h2>
        <p>
          If you want the most control, this is the path. It is more manual than managed DNS, but
          the docs stay canonical so setup details can evolve without making this page stale.
        </p>
      </div>

      <div class="dns-guide-grid">
        <div class="dns-guide-panel dns-guide-panel--primary">
          <h3>Run your own resolver</h3>
          <p>
            Use your own infrastructure, subscribe it to the hapara.fail blocklist, and point your
            devices or network at the resolver you control.
          </p>
          <a class="cta-button" href="https://docs.hapara.fail/self-hosting/dns">
            Open the self-hosting guide
            <ExternalLink size={18} aria-hidden="true" />
          </a>
        </div>

        <div class="dns-guide-panel">
          <ol class="dns-checklist">
            <li>
              <strong>Choose a host.</strong>
              Use a small VPS, home server, or always-on machine.
            </li>
            <li>
              <strong>Deploy the resolver.</strong>
              Follow the docs instead of copying commands from this page.
            </li>
            <li>
              <strong>Point clients at it.</strong>
              Change device or router DNS settings once your resolver is ready.
            </li>
            <li>
              <strong>Keep the list updated.</strong>
              Subscribe to the maintained feed so changes flow in over time.
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section
    id="blocklist-sources"
    class="content-section"
    style="border-top: 1px solid var(--border-color)"
  >
    <div class="container reveal reveal-blur">
      <div class="section-header">
        <h2 class="gradient-text">Blocklist sources</h2>
        <p>
          These feeds remain the source of truth. Use them manually today, and expect the future
          importer tools to read from the same maintained source.
        </p>
      </div>

      <div class="source-card-grid" data-reveal-stagger>
        <article class="source-card reveal reveal-scale">
          <h3>jsDelivr</h3>
          <p>Good for clients that prefer a fast CDN-backed URL.</p>
          <code>https://cdn.jsdelivr.net/gh/hapara-fail/blocklist@main/blocklist.txt</code>
          <a
            href="https://cdn.jsdelivr.net/gh/hapara-fail/blocklist@main/blocklist.txt"
            target="_blank"
            rel="noopener noreferrer"
            class="raw-btn"
          >
            <span>Open jsDelivr feed</span>
          </a>
        </article>

        <article class="source-card reveal reveal-scale">
          <h3>GitHub raw</h3>
          <p>Best for automation that wants the canonical repository source.</p>
          <code
            >https://raw.githubusercontent.com/hapara-fail/blocklist/refs/heads/main/blocklist.txt</code
          >
          <a
            href="https://raw.githubusercontent.com/hapara-fail/blocklist/refs/heads/main/blocklist.txt"
            target="_blank"
            rel="noopener noreferrer"
            class="raw-btn"
          >
            <span>Open GitHub raw feed</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <section
    class="content-section dns-final-cta"
    style="background-color: var(--bg-offset); border-top: 1px solid var(--border-color)"
  >
    <div class="container reveal reveal-blur">
      <div class="dns-guide-panel dns-guide-panel--center">
        <p class="dns-kicker">Still deciding?</p>
        <h2 class="gradient-text">Managed DNS is the easiest path.</h2>
        <p>
          Use NextDNS or Control D if you want the least friction. Self-hosting remains for advanced
          users who want maximum control.
        </p>
        <a class="cta-button" href="#managed-providers">
          Go to the managed path
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>
  <!-- Modals -->
  <div class="dns-modal-overlay" id="nextdns-modal-overlay" hidden>
    <div class="dns-modal" role="dialog" aria-modal="true" aria-labelledby="nextdns-modal-title">
      <button class="dns-modal-close" id="close-nextdns-modal" aria-label="Close modal"
        >&times;</button
      >
      <h2 class="dns-modal-title" id="nextdns-modal-title">NextDNS Importer</h2>

      <!-- Step 1: API Key -->
      <div class="dns-step" id="nextdns-step-1">
        <p class="dns-modal-text">
          First, we need your NextDNS API key. We send this directly to NextDNS and never save it.
        </p>
        <div class="nextdns-importer__field">
          <label for="modal-nextdns-api-key">API Key</label>
          <div class="api-key-input-wrapper">
            <input
              id="modal-nextdns-api-key"
              type="password"
              autocomplete="off"
              spellcheck="false"
              placeholder="Paste your API key"
              required
            />
            <span class="api-key-validation-icon" aria-hidden="true">
              <Check class="api-key-validation-icon__icon api-key-validation-icon__icon--valid" size={18} stroke-width={2.4} />
              <X class="api-key-validation-icon__icon api-key-validation-icon__icon--invalid" size={18} stroke-width={2.4} />
            </span>
          </div>
          <p class="api-key-help-text">
            Find it at the bottom of your <a
              href="https://my.nextdns.io/account"
              target="_blank"
              rel="noopener noreferrer">NextDNS account page</a
            >. You may have to click "Generate API Key" first.
          </p>
        </div>
        <button class="cta-button next-step-btn" id="nextdns-btn-1">
          Continue
          <ArrowRight size={18} aria-hidden="true" />
        </button>
      </div>

      <!-- Step 2: Profile ID -->
      <div class="dns-step fade-in" id="nextdns-step-2" hidden>
        <p class="dns-modal-text">
          Next, paste any NextDNS dashboard URL containing the ID, or just the ID itself.
        </p>
        <div class="nextdns-importer__field">
          <label for="modal-nextdns-profile-id">Setup URL or Profile ID</label>
          <div class="api-key-input-wrapper">
            <input
              id="modal-nextdns-profile-id"
              type="text"
              autocomplete="off"
              spellcheck="false"
              placeholder="e.g. https://my.nextdns.io/2c589b/security or 2c589b"
              required
            />
            <span class="api-key-validation-icon" aria-hidden="true">
              <Check
                class="api-key-validation-icon__icon api-key-validation-icon__icon--valid"
                size={18}
                stroke-width={2.4}
              />
              <X
                class="api-key-validation-icon__icon api-key-validation-icon__icon--invalid"
                size={18}
                stroke-width={2.4}
              />
            </span>
          </div>
          <p>Found anywhere in the URL bar when you are configuring your profile.</p>
        </div>
        <div class="modal-actions-row">
          <button class="cta-button cta-button--secondary back-step-btn" id="nextdns-back-1"
            >Back</button
          >
          <button class="cta-button next-step-btn" id="nextdns-btn-2">
            Start Import
            <ArrowRight size={18} aria-hidden="true" />
          </button>
        </div>
      </div>

      <!-- Step 3: Loading -->
      <div class="dns-step fade-in" id="nextdns-step-3" hidden>
        <div class="import-loading-view">
          <div class="loading-spinner"></div>
          <h3 class="gradient-text">Working our magic...</h3>
          <p class="dns-modal-text" id="nextdns-loading-message">Fetching the blocklist...</p>
          <div class="import-progress-container" id="nextdns-progress-container" hidden>
            <progress
              class="nextdns-importer__progress"
              id="nextdns-import-progress"
              value="0"
              max="100"></progress>
            <p class="eta-message" id="nextdns-eta-message">Calculating time remaining...</p>
          </div>
        </div>
      </div>

      <!-- Step 4: Success -->
      <div class="dns-step fade-in" id="nextdns-step-4" hidden>
        <div class="import-success-view">
          <div class="success-icon-wrapper">
            <Check size={48} stroke-width={2} aria-hidden="true" />
          </div>
          <h3 class="gradient-text">All done!</h3>
          <p class="dns-modal-text" id="nextdns-success-message">
            Your NextDNS profile is now blocking the bad stuff.
          </p>
          <button class="cta-button" id="nextdns-btn-close-success"> Close </button>
        </div>
      </div>
    </div>
  </div>

  <div class="dns-modal-overlay" id="controld-modal-overlay" hidden>
    <div class="dns-modal" role="dialog" aria-modal="true" aria-labelledby="controld-modal-title">
      <button class="dns-modal-close" id="close-controld-modal" aria-label="Close modal"
        >&times;</button
      >
      <h2 class="dns-modal-title" id="controld-modal-title">Control D Importer</h2>
      <div class="dns-step">
        <p class="dns-modal-text">
          We're working closely with Control D to provide a native integration. This feature is
          coming soon.
        </p>
        <div class="provider-placeholder-card__empty-state">
          <span>Importer coming soon</span>
        </div>
        <button
          class="cta-button cta-button--secondary"
          id="controld-btn-close"
          style="margin-top: 20px;"
        >
          Got it
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
