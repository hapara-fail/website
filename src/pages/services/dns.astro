---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import LockOpen from '@lucide/astro/icons/lock-open';
import Ban from '@lucide/astro/icons/ban';
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import ChevronRight from '@lucide/astro/icons/chevron-right';
import Check from '@lucide/astro/icons/check';
import MapPin from '@lucide/astro/icons/map-pin';
import Copy from '@lucide/astro/icons/copy';
import Search from '@lucide/astro/icons/search';
---

<BaseLayout
  title="DNS Service | hapara.fail"
  description="Free DNS that blocks Hapara, GoGuardian, Securly and more. Step-by-step setup for ChromeOS, Windows, macOS, iOS, Android, and Linux."
  canonicalUrl="https://www.hapara.fail/services/dns"
  pageStyles={['/css/dns-service.css']}
  extraScripts={['/js/dns-service.js', '/js/scroll-reveal.js']}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'hapara.fail DNS',
    url: 'https://www.hapara.fail/services/dns',
    description:
      'Free DNS that blocks Hapara, GoGuardian, Securly and more. Step-by-step setup for ChromeOS, Windows, macOS, iOS, Android, and Linux.',
    provider: {
      '@type': 'Organization',
      name: 'hapara.fail',
      url: 'https://www.hapara.fail/',
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.hapara.fail/images/favicon-96x96.png',
      },
    },
    areaServed: 'Worldwide',
    serviceType: 'DNS filtering',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
  }}
>
  <section class="page-hero">
    <div class="parallax-bg"></div>
    <div class="container reveal reveal-blur">
      <h1 class="gradient-text">Take Back Your Network</h1>
      <p>
        Use our free, custom-configured DNS service to disable invasive school spyware and bypass
        restrictive web filters with a single change to your network settings.
      </p>
      <button id="view-ips-btn" class="cta-button" style="padding: 12px 32px; font-size: 1.1rem">
        View Servers
      </button>
    </div>
  </section>

  <section
    class="content-section"
    style="background-color: var(--bg-offset); border-top: 1px solid var(--border-color)"
  >
    <div class="container">
      <div class="benefits-grid" data-reveal-stagger>
        <div class="benefit-card reveal reveal-scale">
          <ShieldCheck class="icon" size={32} stroke-width={1.5} aria-hidden="true" />
          <div>
            <h3>Block Spyware</h3>
            <p>
              Our service maintains a real-time blocklist of servers used by GoGuardian, Hapara,
              Securly, and more. If their software can't phone home, it can't watch you.
            </p>
          </div>
        </div>
        <div class="benefit-card reveal reveal-scale">
          <LockOpen class="icon" size={32} stroke-width={1.5} aria-hidden="true" />
          <div>
            <h3>Bypass Filters</h3>
            <p>
              By routing your DNS requests through our servers instead of your school's, you
              sidestep their category-based web filters, unlocking access to a more open internet.
            </p>
          </div>
        </div>
        <div class="benefit-card reveal reveal-scale">
          <Ban class="icon" size={32} stroke-width={1.5} aria-hidden="true" />
          <div>
            <h3>Block Ads</h3>
            <p>
              Our DNS includes the comprehensive HaGeZi blocklist, automatically blocking ads,
              trackers, and malicious domains for a cleaner, faster, and safer browsing experience.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="setup" class="content-section">
    <div class="container reveal reveal-blur">
      <div class="section-header">
        <h2 class="gradient-text">Instructions</h2>
      </div>

      <svg class="platform-icon-sprite" aria-hidden="true" focusable="false">
        <symbol id="platform-icon-windows" viewBox="0 0 640 640">
          <path
